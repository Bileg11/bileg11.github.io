{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git",
      ".gitignore",
      "*.mp4",
      "node_modules"
    ],
    "rewrites": [
      { "source": "/login", "destination": "/login/index.html" },
      { "source": "/booking", "destination": "/booking/index.html" },
      { "source": "/admin", "destination": "/admin/index.html" },
      { "source": "/profile/**", "destination": "/profile/index.html" },
      { "source": "/profile", "destination": "/profile/index.html" },
      { "source": "/mn", "destination": "/mn/index.html" },
      { "source": "/en", "destination": "/en/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|png|webp|gif|svg)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
      }
    ]
  }
}
